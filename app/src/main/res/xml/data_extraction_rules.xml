<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    Controls what gets included in cloud backups and device-to-device transfers.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="habiwabi.db" />
        <include domain="database" path="habiwabi.db-shm" />
        <include domain="database" path="habiwabi.db-wal" />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="habiwabi.db" />
        <include domain="database" path="habiwabi.db-shm" />
        <include domain="database" path="habiwabi.db-wal" />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
